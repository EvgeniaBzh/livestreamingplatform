{
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "daisyui": "^5.0.37",
    "lucide-react": "^0.577.0",
    "tailwindcss": "^4.1.7"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{js,jsx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
